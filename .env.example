# ── Fridge Observer — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── AI APIs ───────────────────────────────────────────────────
# K2-Think API key (required for AI assistant features)
K2_API_KEY=your-k2-api-key-here

# Google Gemini API key (required for image-based food identification)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────
# Path to the SQLite database file (default: fridge.db in project root)
FRIDGE_DB_PATH=fridge.db

# ── Server ────────────────────────────────────────────────────
# Host and port for the uvicorn server
HOST=0.0.0.0
PORT=8000

# ── Auth ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-before-deploying

# ── Hugging Face ──────────────────────────────────────────────
# Used for FLUX.1-schnell image generation (recipe images, product blueprints, food item images)
HF_TOKEN=your-hugging-face-token-here
